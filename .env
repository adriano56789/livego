# Ambiente de Desenvolvimento
NODE_ENV=development

# Configuração do SRS para desenvolvimento local
SRS_API_URL=http://localhost:1985
SRS_API_TOKEN=

# Configuração do MongoDB
MONGODB_URI=mongodb://admin:adriano123@localhost:27017/api?authSource=admin

# Configuração do JWT
JWT_SECRET=livego_jwt_secret_development
JWT_EXPIRES_IN=7d

# Configuração do WebSocket
WS_PORT=3001

# Configuração do servidor
PORT=3000
HOST=localhost

# Configuração de upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Configuração de email (opcional para desenvolvimento)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Configuração de logs
LOG_LEVEL=debug

# Configuração do servidor TURN para WebRTC
VITE_TURN_SERVER=stun:stun.l.google.com:19302
VITE_TURN_USER=livego
VITE_TURN_PASS=livego123
VITE_TURN_URL=turn:numb.viagenie.ca:3478
