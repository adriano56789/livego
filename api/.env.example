# Configuração do Servidor
NODE_ENV=development
PORT=3000

# Banco de Dados
MONGODB_URI=mongodb://localhost:27017/livego

# Autenticação
JWT_SECRET=seu_segredo_jwt_aqui
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# SRS (Simple RTMP Server)
SRS_API=http://localhost:1985
SRS_RTMP_URL=rtmp://localhost:1935/live
SRS_HTTP_URL=http://localhost:8080/live

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3001

# Configurações de E-mail (opcional)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=seu_email@gmail.com
# EMAIL_PASS=sua_senha_aqui
# EMAIL_FROM=LiveGo <noreply@livego.com>
