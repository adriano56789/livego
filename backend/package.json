{
  "name": "livego-backend",
  "version": "1.0.0",
  "description": "Backend for LiveGO Stream Viewer API",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "import-real-data": "ts-node scripts/importRealData.ts",
    "check-users": "ts-node scripts/checkRealUsers.ts",
    "register-activity": "ts-node scripts/registerUserActivity.ts",
    "ensure-real-ids": "ts-node scripts/ensureRealIds.ts",
    "test-follow": "ts-node scripts/testFollowSystem.ts",
    "test-followers": "ts-node scripts/testFollowersCollection.ts",
    "migrate-followers": "ts-node scripts/migrateToFollowers.ts",
    "clean-followers": "ts-node scripts/cleanFollowers.ts",
    "create-conversations": "ts-node scripts/createConversations.ts",
    "create-blocks": "ts-node scripts/createBlocks.ts",
    "create-birthdays": "ts-node scripts/createBirthdays.ts",
    "restore-gifts": "ts-node scripts/restoreOriginalGifts.ts",
    "create-comments": "ts-node scripts/createComments.ts",
    "create-profile-photos": "ts-node scripts/createProfilePhotos.ts",
    "verify-profile-photos": "ts-node scripts/verifyProfilePhotos.ts",
    "create-real-follow-stats": "ts-node scripts/createRealFollowStats.ts",
    "verify-real-follow-stats": "ts-node scripts/verifyRealFollowStats.ts",
    "create-real-chat": "ts-node scripts/createRealChat.ts",
    "verify-real-chat": "ts-node scripts/verifyRealChat.ts",
    "ensure-real-data": "ts-node scripts/ensureRealData.ts",
    "test-websocket": "ts-node scripts/testWebSocket.ts",
    "check-network": "ts-node scripts/checkNetworkConfig.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.3.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.7",
    "@types/socket.io": "^3.0.2",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
