{
  "name": "livego-stream-viewer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "description": "Aplicativo LiveGo (viewer) com pacote PWA e instaladores",
  "author": "Adriano",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "analyze": "vite build --mode production",
    "pwa-dev": "vite -c vite.pwa.config.ts",
    "pwa-build": "vite build -c vite.pwa.config.ts",
    "pwa-preview": "vite preview -c vite.pwa.config.ts",
    "electron-dev": "npm run build && electron ./electron/main.js",
    "electron-build": "npm run build && electron-builder -w",
    "electron-pack": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@types/lodash.debounce": "^4.0.9",
    "i18next": "^25.6.1",
    "lodash.debounce": "^4.0.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.2.4",
    "react-icons": "^5.5.0",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@tailwindcss/postcss7-compat": "^2.2.17",
    "@types/node": "^22.19.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^9.8.8",
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3",
    "postcss": "^7.0.39",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^4.1.17",
    "terser": "^5.44.1",
    "typescript": "~5.8.2",
    "vite": "^7.2.2",
    "vite-plugin-checker": "^0.11.0"
  },
  "build": {
    "appId": "com.livego.app",
    "productName": "LiveGo",
    "directories": {
      "output": "release-win"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
